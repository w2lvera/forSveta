void moveLeft(char* s, int k, int n) {
    for (int i = 0; i < k+1; i++) {
        char h = s[n];
        int j;
        for (j = n; j > 0; j--) {
            s[j] = s[j - 1];
        }
        s[j] = ' ';
    }
}
