void copy(char* str, char* word) {
    for (int i = 0; i < strlen(word); i++)
        str[i] = word[i];
}

void insertWord(char* str, char* word, int n,int nWords) {
    char* pStr = str;
    int kWords = 0;
    while (kWords<=nWords) {
        char wordComp[100];
        sscanf_s(pStr, "%s", wordComp, 100);
        kWords++;
        if (strcmp(wordComp, word) > 0) {
            moveLeft(pStr, strlen(word), n);
            copy(pStr, word);
            break;
        }
        pStr += strlen(wordComp) + 1;
        n -= strlen(wordComp);
    }
}
